#!ipxe
{% include '_ipxe_debug.inc.j2' %}

########################################
# Menu iPXE central — généré automatiquement
# {{ server_url }}
########################################

set menu-timeout 30000
set menu-default local

:start
{% include '_theme.inc.j2' %}
menu === iPXE Boot Manager ===
{% for ot in os_types %}
item {{ ot.slug }} {{ ot.label }}
{% endfor %}
item --gap
{% if remote_chains %}
item --gap -- === Serveurs distants ===
{% for rc in remote_chains %}
item remote_{{ rc.id }} {{ rc.name }}
{% endfor %}
item --gap
{% endif %}
item local      Démarrer sur le disque local
item shell      Shell iPXE
item reboot     Redémarrer
choose --timeout ${menu-timeout} --default ${menu-default} selected || goto local
goto ${selected}

{% for ot in os_types %}
:{{ ot.slug }}
chain --autofree {{ server_url }}/menus/{{ ot.slug }}.ipxe || goto start
{% endfor %}

{% if remote_chains %}
########################################
# Serveurs distants
########################################
{% for rc in remote_chains %}
:remote_{{ rc.id }}
chain --autofree {{ rc.url }} || goto start
{% endfor %}
{% endif %}

:local
# Ne pas utiliser « exit » ici : le script embarqué (embed.ipxe) le voit comme un échec de chain.
sanboot --no-describe --drive 0x80 ||
sanboot --no-describe --drive 0x81 ||
sanboot --no-describe --drive 0x82 ||
echo Echec demarrage disque local — retour menu &&
sleep 3 &&
goto start

:shell
shell

:reboot
reboot
