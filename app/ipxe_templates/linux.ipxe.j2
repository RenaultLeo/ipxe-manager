#!ipxe

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
########################################

:start
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}{% if e.autoconfigs %} [+conf]{% endif %}

{% endfor %}
item --gap
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
{% if e.autoconfigs %}
  menu {{ e.label }} — Configuration automatique
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item manual Installation manuelle
  item --gap
  item back_v Retour
  choose conf || goto manual_{{ e.id }}
  goto ${conf}
  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    kernel {{ e.kernel }} {{ e.kernel_args }} auto-install/enable=true url={{ ac.url }}
    initrd {{ e.initrd }}
    boot
  {% endfor %}
  :manual_{{ e.id }}
{% endif %}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  initrd {{ e.initrd }}
  boot

{% endfor %}

:back
chain --autofree {{ server_url }}/menus/menu.ipxe
