#!ipxe

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
########################################
{% if os_type.slug == "ubuntu" and ubuntu_nfs_enabled %}
# Ubuntu : vmlinuz/initrd en HTTP ; casper : netboot=nfs, nfsroot=hôte:chemin disque, nfsopts= dans la ligne kernel (cf. casper(7)).
# Export NFS typique : {{ ubuntu_nfs_export_path }}/
{% endif %}

:start
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}{% if e.autoconfigs %} [+conf]{% endif %}

{% endfor %}
item --gap
{% if has_autres %}
item autres Autres versions {{ os_type.label }}…
{% endif %}
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
{% if e.autoconfigs %}
  menu {{ e.label }} — Choisissez une configuration
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item --gap
  item manual_{{ e.id }} Installation manuelle (sans config)
  item back_v Retour
  choose conf || goto back_v
  goto ${conf}

  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    {% if ac.boot_arg %}
    kernel {{ e.kernel }} {{ e.kernel_args }} {{ ac.boot_arg }}
    {% else %}
    kernel {{ e.kernel }} {{ e.kernel_args }}
    {% endif %}
    {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
    boot
  {% endfor %}

  :manual_{{ e.id }}
{% endif %}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
  boot

{% endfor %}

{% if has_autres %}
:autres
chain --autofree {{ server_url }}/menus/{{ os_type.slug }}_autres.ipxe

{% endif %}
:back
chain --autofree {{ server_url }}/menus/menu.ipxe
