#!ipxe
{% include '_ipxe_debug.inc.j2' %}

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
########################################
{% if os_type.slug == "ubuntu" %}
{% if ubuntu_nfs_enabled %}
# Ubuntu NFS : vmlinuz/initrd en HTTP ; casper monte le squashfs via nfsroot= (export typique : {{ ubuntu_nfs_export_path }}/).
{% else %}
# Ubuntu HTTP autoinstall : root=/dev/ram0, url= ISO si présente ; configs [+conf] ajoutent autoinstall ds=nocloud-net + cloud-config-url=/dev/null.
{% endif %}
{% endif %}

:start
{% include '_theme.inc.j2' %}
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}{% if e.autoconfigs %} [+conf]{% endif %}

{% endfor %}
item --gap
{% if has_autres %}
item autres Fichiers iPXE personnalisés pour {{ os_type.label }}…
{% endif %}
item back {{ back_item_label if back_item_label is defined else 'Retour au menu principal' }}
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
{% if e.autoconfigs %}
  menu {{ e.label }} — Choisissez une configuration
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item --gap
  item manual_{{ e.id }} Installation manuelle (sans config)
  item back_v{{ e.id }} Retour
  choose conf || goto back_v{{ e.id }}
  goto ${conf}

  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    {% if ac.boot_arg %}
    kernel {{ e.kernel }} {{ e.kernel_args }} {{ ac.boot_arg }}
    {% else %}
    kernel {{ e.kernel }} {{ e.kernel_args }}
    {% endif %}
    {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
    boot
  {% endfor %}

  :manual_{{ e.id }}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
  boot

  :back_v{{ e.id }}
  goto start

{% else %}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
  boot
{% endif %}

{% endfor %}

{% if has_autres %}
:autres
chain --autofree {{ server_url }}/menus/{{ os_type.slug }}_autres.ipxe

{% endif %}
:back
chain --autofree {{ back_menu_url if back_menu_url is defined else (server_url ~ '/menus/menu.ipxe') }}
