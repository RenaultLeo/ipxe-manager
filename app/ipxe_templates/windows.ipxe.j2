#!ipxe

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
# Utilise iPXE wimboot pour charger boot.wim
########################################

:start
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}
{% endfor %}
item --gap
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
  kernel {{ server_url }}/wimboot
  initrd {{ e.boot_wim }} boot.wim
  boot

{% endfor %}

:back
chain --autofree {{ server_url }}/menus/menu.ipxe
