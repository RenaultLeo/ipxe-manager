#!ipxe

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
# Boot HTTP via wimboot (BCD + boot.sdi + boot.wim)
########################################

:start
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}{% if e.autoconfigs %} [+conf]{% endif %}

{% endfor %}
item --gap
{% if has_autres %}
item autres Autres versions {{ os_type.label }}…
{% endif %}
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
{% if e.autoconfigs %}
  menu {{ e.label }} — Choisissez une configuration
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item --gap
  item manual_{{ e.id }} Installation manuelle (sans config)
  item back_v Retour
  choose conf || goto back_v
  goto ${conf}

  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    kernel {{ server_url }}/wimboot
    {% if e.bcd %}initrd {{ e.bcd }} BCD{% endif %}
    {% if e.boot_sdi %}initrd {{ e.boot_sdi }} boot.sdi{% endif %}
    {% if e.boot_wim %}initrd {{ e.boot_wim }} boot.wim{% endif %}
    initrd {{ ac.url }} autounattend.xml
    boot
  {% endfor %}

  :manual_{{ e.id }}
{% endif %}
  kernel {{ server_url }}/wimboot
{% if e.bcd %}
  initrd {{ e.bcd }} BCD
{% endif %}
{% if e.boot_sdi %}
  initrd {{ e.boot_sdi }} boot.sdi
{% endif %}
{% if e.boot_wim %}
  initrd {{ e.boot_wim }} boot.wim
{% endif %}
{% if e.unattend_url %}
  initrd {{ e.unattend_url }} autounattend.xml
{% endif %}
  boot

{% endfor %}

{% if has_autres %}
:autres
chain --autofree {{ server_url }}/menus/{{ os_type.slug }}_autres.ipxe

{% endif %}
:back
chain --autofree {{ server_url }}/menus/menu.ipxe
