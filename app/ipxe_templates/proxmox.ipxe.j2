#!ipxe

########################################
# Sous-menu {{ os_type.label }} — généré automatiquement
# low_ram : initrd-netboot.img + isourl= (ISO wget en initramfs, ~4 GiB)
# dual_initrd : initrd.img + 2e initrd ISO HTTP (alias proxmox.iso, ~6+ GiB)
########################################

:start
{% include '_theme.inc.j2' %}
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item v{{ e.id }} {{ e.label }}{% if e.autoconfigs %} [+conf]{% endif %}

{% endfor %}
item --gap
{% if has_autres %}
item autres Fichiers iPXE personnalisés pour {{ os_type.label }}…
{% endif %}
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:v{{ e.id }}
{% if e.proxmox_boot_incomplete %}
goto pve_setup_{{ e.id }}
{% elif e.autoconfigs %}
  menu {{ e.label }} — Choisissez une configuration
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item --gap
  item manual_{{ e.id }} Installation manuelle (sans answer.toml)
  item back_v{{ e.id }} Retour
  choose conf || goto back_v{{ e.id }}
  goto ${conf}

  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    kernel {{ e.kernel }} {{ e.kernel_args }} {{ ac.boot_arg }}
    {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
    {% if e.proxmox_boot_mode == 'dual_initrd' and e.proxmox_iso_url %}
    initrd {{ e.proxmox_iso_url }} proxmox.iso
    {% endif %}
    boot || goto pve_fail_{{ e.id }}
  {% endfor %}

  :manual_{{ e.id }}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
  {% if e.proxmox_boot_mode == 'dual_initrd' and e.proxmox_iso_url %}
  initrd {{ e.proxmox_iso_url }} proxmox.iso
  {% endif %}
  boot || goto pve_fail_{{ e.id }}

  :back_v{{ e.id }}
  goto start

{% else %}
  kernel {{ e.kernel }} {{ e.kernel_args }}
  {% if e.initrd %}initrd {{ e.initrd }}{% endif %}
  {% if e.proxmox_boot_mode == 'dual_initrd' and e.proxmox_iso_url %}
  initrd {{ e.proxmox_iso_url }} proxmox.iso
  {% endif %}
  boot || goto pve_fail_{{ e.id }}
{% endif %}

:pve_fail_{{ e.id }}
echo
echo Echec boot Proxmox {{ e.label }}
echo Verifier : initrd-netboot.img (low_ram) ou proxmox.iso (dual_initrd), re-extraire l ISO
sleep 8
goto start

:pve_setup_{{ e.id }}
echo
echo Proxmox {{ e.label }} : mode low_ram incomplet
echo initrd-netboot.img absent sous boot/proxmox/
echo Serveur : apt install squashfs-tools zstd bsdtar
echo Puis re-extraire l ISO et regenerer les menus
echo .env : PROXMOX_BOOT_DELIVERY=low_ram
sleep 12
goto start

{% endfor %}

{% if has_autres %}
:autres
chain --autofree {{ server_url }}/menus/{{ os_type.slug }}_autres.ipxe

{% endif %}
:back
chain --autofree {{ server_url }}/menus/menu.ipxe
