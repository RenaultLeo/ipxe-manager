#!ipxe

########################################
# Sous-menu {{ os_type.label }} — UEFI : mboot.efi (copie bootx64.efi, doc VMware) ; Legacy : mboot.c32
# imgargs : basename chargeur ; -c URL ipxe-boot.cfg (identique UEFI / Legacy) ;
# puis BOOTIF (${net0/mac:hexhyp}) ; les ``module`` suivent le JSON du profil (ordre VMware).
########################################

:start
{% include '_theme.inc.j2' %}
menu === {{ os_type.label }} — Choisissez une version ===
{% for e in entries %}
item {{ e.ipxe_item_tag }} {{ e.label }}{% if e.autoconfigs %} [+kickstart/conf]{% endif %}

{% endfor %}
item --gap
{% if has_autres %}
item autres Fichiers iPXE personnalisés pour {{ os_type.label }}…
{% endif %}
item back Retour au menu principal
choose selected || goto back
goto ${selected}

{% for e in entries %}
:{{ e.ipxe_item_tag }}
{% set mbasename = e.esxi_mboot_basename or 'mboot.c32' %}
{% set esxi_bootif_arg = "BOOTIF=01-${net0/mac:hexhyp}" %}
{% if e.autoconfigs %}
  menu {{ e.label }} — Fichier d'installation automatique
  {% for ac in e.autoconfigs %}
  item ac{{ ac.id }} {{ ac.label }}
  {% endfor %}
  item --gap
  item manual_{{ e.ipxe_item_tag }} Installation manuelle (sans kickstart / args supplémentaires)
  item back_v Retour
  choose conf || goto back_v
  goto ${conf}

  {% for ac in e.autoconfigs %}
  :ac{{ ac.id }}
    kernel {{ e.kernel }}
    imgargs {{ mbasename }} -c {{ e.esxi_boot_cfg }} {{ esxi_bootif_arg }}{% if e.kernel_args %} {{ e.kernel_args }}{% endif %}{% if ac.boot_arg %} {{ ac.boot_arg }}{% endif %}

    {% for u in e.esxi_module_urls %}
    module {{ u }}
    {% endfor %}
    boot
  {% endfor %}

  :manual_{{ e.ipxe_item_tag }}
{% endif %}
  kernel {{ e.kernel }}
  imgargs {{ mbasename }} -c {{ e.esxi_boot_cfg }} {{ esxi_bootif_arg }}{% if e.kernel_args %} {{ e.kernel_args }}{% endif %}

  {% for u in e.esxi_module_urls %}
  module {{ u }}
  {% endfor %}
  boot

{% endfor %}

{% if has_autres %}
:autres
chain --autofree {{ server_url }}/menus/{{ os_type.slug }}_autres.ipxe

{% endif %}
:back
chain --autofree {{ server_url }}/menus/menu.ipxe
