# Copier ce fichier en .env et adapter les valeurs

# URL de base du serveur (menus iPXE / URLs dans l’UI). HTTPS recommandé si Nginx écoute en 443
# (cert auto-signé : compiler le firmware avec le PEM correspondant via IPXE_TLS_TRUSTED_PEM / TRUST=).
SERVER_BASE_URL=https://192.168.2.6

# Secret pour les sessions (changer impérativement en production)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# Mot de passe admin (sera haché en bcrypt au premier démarrage)
ADMIN_PASSWORD=admin

# Base de données (SQLite par défaut, PostgreSQL possible)
DATABASE_URL=sqlite:////srv/ipxe/app/ipxe.db

# Redis pour Celery
REDIS_URL=redis://localhost:6379/0

# Répertoires de données
TFTP_ROOT=/srv/ipxe/tftpboot
HTTP_ROOT=/srv/ipxe/http
ISO_ROOT=/srv/ipxe/isos
# Segment d’URL Nginx pour les ISO : https://serveur/<ISO_HTTP_ALIAS>/… → ISO_ROOT (voir deploy/setup.sh).
ISO_HTTP_ALIAS=isos-ipxe
BUILD_DIR=/srv/ipxe/build

# PEM incorporé dans les firmwares iPXE (make TRUST=…) pour chaînes HTTPS — défaut si absent dans l’app
IPXE_TLS_TRUSTED_PEM=/srv/ipxe/certs/ipxe-manager/server.crt

# Taille max d'upload en octets (défaut 50 GB)
MAX_UPLOAD_SIZE=53687091200

# Marge disque minimale (octets) avant d'accepter un upload ISO (défaut 256 Mo ; réglable si disque serré).
# UPLOAD_MIN_FREE_BYTES=268435456

# Timeout d'extraction ISO en secondes
EXTRACT_TIMEOUT=3600

# ── Ubuntu : live/install depuis NFS (ISO sous HTTP_ROOT/boot/ubuntu/<slug>)
# true = casper : netboot=nfs nfsroot=<hôte>:<HTTP_ROOT>/boot/ubuntu/<slug> [nfsopts=…]
# (UBUNTU_NFS_MOUNT_OPTS → nfsopts=, pas de « ,vers= » collé à nfsroot — voir casper(7).)
UBUNTU_NFS_ENABLED=false
# Vide = 192.168.2.6 dans nfsroot= ; sinon IP/hostname NFS joignable par les clients PXE
UBUNTU_NFS_HOST=
UBUNTU_NFS_MOUNT_OPTS=vers=4,tcp
