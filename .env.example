# Copier ce fichier en .env et adapter les valeurs

# URL de base du serveur HTTP (visible par les clients PXE)
SERVER_BASE_URL=http://192.168.2.6

# Secret pour les sessions (changer impérativement en production)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# Mot de passe admin (sera haché en bcrypt au premier démarrage)
ADMIN_PASSWORD=admin

# Base de données (SQLite par défaut, PostgreSQL possible)
DATABASE_URL=sqlite:////srv/ipxe/app/ipxe.db

# Redis pour Celery
REDIS_URL=redis://localhost:6379/0

# Répertoires de données
TFTP_ROOT=/srv/ipxe/tftpboot
HTTP_ROOT=/srv/ipxe/http
ISO_ROOT=/srv/ipxe/isos
BUILD_DIR=/srv/ipxe/build

# Taille max d'upload en octets (défaut 50 GB)
MAX_UPLOAD_SIZE=53687091200

# Timeout d'extraction ISO en secondes
EXTRACT_TIMEOUT=3600

# ── Ubuntu : live/install depuis NFS (ISO extraite sous HTTP_ROOT/boot/ubuntu/<slug>)
# true = nfsroot=<hôte>:/boot/ubuntu/<slug>(,opts) — même logique que l’URL HTTP /boot/ubuntu/… sous Nginx.
UBUNTU_NFS_ENABLED=false
# Vide = 192.168.2.6 dans nfsroot= ; sinon IP/hostname NFS joignable par les clients PXE
UBUNTU_NFS_HOST=
UBUNTU_NFS_MOUNT_OPTS=vers=4,tcp
