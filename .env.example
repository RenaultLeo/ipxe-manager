# Copier ce fichier en .env et adapter les valeurs

# URL de base (menus iPXE, liens ISO). En prod : http://<IP ou FQDN PXE>.
# Si absent : défaut applicatif = http://<IPv4 route locale>.
# SERVER_BASE_URL=http://192.168.x.x

# Secret pour les sessions (changer impérativement en production)
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# Mot de passe admin (sera haché en bcrypt au premier démarrage)
ADMIN_PASSWORD=admin

# Base de données (SQLite par défaut, PostgreSQL possible)
DATABASE_URL=sqlite:////srv/ipxe/app/ipxe.db

# Redis pour Celery
REDIS_URL=redis://localhost:6379/0

# Répertoires de données
TFTP_ROOT=/srv/ipxe/tftpboot
HTTP_ROOT=/srv/ipxe/http
ISO_ROOT=/srv/ipxe/isos
# Segment d’URL Nginx pour les ISO : http://serveur/<ISO_HTTP_ALIAS>/… → ISO_ROOT (voir deploy/setup.sh).
ISO_HTTP_ALIAS=isos-ipxe
BUILD_DIR=/srv/ipxe/build

# Taille max d'upload en octets (défaut 50 GB)
MAX_UPLOAD_SIZE=53687091200

# Marge disque minimale (octets) avant d'accepter un upload ISO (défaut 256 Mo ; réglable si disque serré).
# UPLOAD_MIN_FREE_BYTES=268435456

# Timeout d'extraction ISO en secondes
EXTRACT_TIMEOUT=3600

# ── Ubuntu autoinstall (défaut HTTP : root=/dev/ram0, url= ISO, nocloud-net sur les configs auto)
# NFS optionnel : true = casper netboot=nfs nfsroot=… (UBUNTU_NFS_MOUNT_OPTS → nfsopts=, voir casper(7))
UBUNTU_NFS_ENABLED=false
UBUNTU_RAMDISK_SIZE=1500000
PROXMOX_RAMDISK_SIZE=16777216
# Proxmox PXE : auto = ISO HTTP (2e initrd proxmox.iso) si ISO présente, sinon url= vers boot/ extrait
# iso_http | extracted_http | auto
PROXMOX_BOOT_DELIVERY=auto
PROXMOX_VGA_PARAMS=true
# Vide : hôte nfsroot dérivé de SERVER_BASE_URL, sinon première IPv4 locale — ou IP NFS explicite ici.
UBUNTU_NFS_HOST=
UBUNTU_NFS_MOUNT_OPTS=vers=4,tcp
